package pe_12_14;

import java.io.File;
import java.io.FileNotFoundException;
import java.util.Scanner;

class ReadingSortedFile {
	public static void main(String [] args) {
		if (args.length != 2) {
			System.out.println("String line java Exercise12_12 Test.java");
			System.exit(1);
			}
		// Check if source file exists
		File file = new File(args[1]);
			if (!file.exists()) {
				System.out.println("Source file " + args[0] + " does not exist");
				System.exit(2);
				}
		System.out.println("Position number of a line " + args[0] + " is " + readInFile(args[0], file));	
			
	}
	
	
	public static int readInFile (String line, File file)   {
		int counterLine = 0;
		try (
				// Create input and output files
				Scanner input = new Scanner(file);
				) {
				
				while (input.hasNext()) {
					String s1 = input.nextLine();
					counterLine++;
					if(s1.matches(line))
						return counterLine;
									
					}
				} catch (FileNotFoundException e) {
					// TODO Auto-generated catch block
					e.printStackTrace();
				}
		return -1;
	}
}
